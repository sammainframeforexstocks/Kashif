function normalize(text) {
  return (text || "").toLowerCase().trim();
}

function titleCase(text) {
  return text
    .split(" ")
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
}

function detectServices(text) {
  const haystack = normalize(text);
  const matches = [];

  for (const rule of REGULATED_SERVICE_RULES) {
    const hitKeywords = rule.keywords.filter((k) => haystack.includes(k));
    if (hitKeywords.length) {
      matches.push({
        id: rule.id,
        label: rule.label,
        keywords: hitKeywords,
        riskNote: rule.riskNote,
      });
    }
  }

  return matches;
}

function detectLocation(text) {
  const haystack = normalize(text);
  const found = [];

  for (const rule of JURISDICTION_RULES) {
    if (rule.keywords.some((k) => haystack.includes(k))) {
      found.push(rule.label);
    }
  }

  return [...new Set(found)];
}

function deriveAssessment({ services, regulators }) {
  const anyRegulatorFound = [regulators.cbuae, regulators.dfsa, regulators.adgmFsra].some((r) => r?.found);

  if (anyRegulatorFound && services.length === 0) {
    return {
      tone: "neutral",
      label: "Licensed entity found; website service classification unclear",
      summary:
        "A regulator match was identified, but the current website text does not clearly map to a regulated activity category in the screening logic.",
    };
  }

  if (anyRegulatorFound && services.length > 0) {
    return {
      tone: "positive",
      label: "Potentially licensed and broadly aligned",
      summary:
        "A regulator match was identified and the website appears to market financial services. Manual review is still recommended to confirm that website offerings do not exceed the visible permitted scope.",
    };
  }

  if (!anyRegulatorFound && services.length > 0) {
    return {
      tone: "warning",
      label: "Potential unlicensed activity",
      summary:
        "The website appears to market regulated financial services, but no corresponding licence or authorisation was identified in the checked regulator registers.",
    };
  }

  return {
    tone: "neutral",
    label: "No confirmed regulator match; insufficient regulated-service indicators",
    summary:
      "No regulator match was identified, and the website text does not currently contain strong enough keywords to classify a regulated financial activity with confidence.",
  };
}

function generateObservation({ companyName, services, regulators, website, locationText }) {
  const anyRegulatorFound = [regulators.cbuae, regulators.dfsa, regulators.adgmFsra].some((r) => r?.found);
  const serviceLabel = services.map((s) => s.label).join("; ") || "regulated financial services";
  const locationPart = locationText ? ` The website also indicates a UAE presence or operating base in ${locationText}.` : "";

  if (!anyRegulatorFound && services.length > 0) {
    return `Based on the website information reviewed for ${companyName}, the company appears to offer ${serviceLabel}. A search of the checked public financial regulator registers did not identify a corresponding licence or authorisation for the entity under the Central Bank of the UAE (CBUAE), Dubai Financial Services Authority (DFSA), or Abu Dhabi Global Market Financial Services Regulatory Authority (ADGM FSRA).${locationPart} Accordingly, the company appears to market or provide a regulated financial service without a clearly identifiable valid licence in the checked registers, and the matter should be subject to further regulatory verification.\n\nThis observation is based on publicly available information reviewed as part of preliminary screening and does not constitute a final regulatory or legal determination.`;
  }

  const foundRegulators = [
    regulators.cbuae?.found ? "CBUAE" : null,
    regulators.dfsa?.found ? "DFSA" : null,
    regulators.adgmFsra?.found ? "ADGM FSRA" : null,
  ]
    .filter(Boolean)
    .join(", ");

  return `A corresponding regulator match was identified for ${companyName} in the following checked register(s): ${foundRegulators || "N/A"}. The website appears to market ${serviceLabel}. Manual review is recommended to confirm whether the website offering is fully aligned with the visible licensed or authorised scope and the specific legal entity holding the permission.\n\nThis observation is based on publicly available information reviewed as part of preliminary screening and does not constitute a final regulatory or legal determination.`;
}

function toneClasses(tone) {
  if (tone === "positive") {
    return "bg-emerald-50 text-emerald-700 border-emerald-200";
  }
  if (tone === "warning") {
    return "bg-amber-50 text-amber-700 border-amber-200";
  }
  return "bg-slate-50 text-slate-700 border-slate-200";
}

function StatusBadge({ found }) {
